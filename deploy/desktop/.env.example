# Vexa Desktop (deploy/desktop) — local, hot, no Docker.
# STT itself is read by the backend from modules/pipeline/.env (remote endpoint).
# These just wire ports + the lite-db location for the orchestrator.

INGEST_PORT=9099
GATEWAY_PORT=8056
DASHBOARD_PORT=3001

# lite-db: one SQLite file, the all-Node control plane (no Postgres)
VEXA_DESKTOP_DB=~/.vexa/desktop.db

# where collected fixtures land (recording tee)
# VEXA_FIXTURE_CACHE=~/.vexa/fixtures

# run a subset:
# DESKTOP_NO_DASHBOARD=1   # backend + extension only
# DESKTOP_NO_EXTENSION=1   # backend (+ dashboard) only

# live-stack (npm run dev) — the local backend the product extension talks to.
# Copy to .env and fill the token:  cp .env.example .env

# STT: hosted Whisper, or your own OpenAI-compatible /v1/audio/transcriptions endpoint.
TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai
TRANSCRIPTION_SERVICE_TOKEN=

# Ports: the extension's sidepanel `ingestUrl` → ws://localhost:INGEST_PORT/ingest;
# the sidepanel's `gatewayUrl` → http://localhost:GATEWAY_PORT.
INGEST_PORT=9099
GATEWAY_PORT=8056

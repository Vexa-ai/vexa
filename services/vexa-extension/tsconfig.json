{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["chrome"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@vexa/capture": ["../../modules/capture/src/index.ts"],
      "@vexaai/transcript-rendering": ["../../packages/transcript-rendering/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}

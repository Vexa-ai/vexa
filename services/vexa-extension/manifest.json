{
  "manifest_version": 3,
  "name": "Vexa — in-tab transcription",
  "version": "0.1.0",
  "description": "Transcribe the Google Meet you are already in — no bot, no waiting room. Captures audio in your own tab and streams it to your Vexa pipeline.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Vexa in-tab transcription" },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}

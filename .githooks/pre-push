#!/bin/sh
# pre-push — the gate suite is the bar (ARCHITECTURE.md P9): no push that isn't
# gate-green. Zero-dependency by design (P17) — a committed hook activated via
# `core.hooksPath` (the root package.json `prepare` script wires it on install),
# not husky. Emergency bypass: `git push --no-verify` (then fix it).
root="$(git rev-parse --show-toplevel)" || exit 1
cd "$root" || exit 1
echo "▶ pre-push → pnpm gates (full suite)…"
pnpm gates || {
  echo "✗ pre-push: gates FAILED — push aborted (fix the gate above, or bypass with: git push --no-verify)."
  exit 1
}
echo "✓ pre-push: gates green — pushing."

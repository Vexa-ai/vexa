{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zaki.ai/contracts/minutes/zaki-read.v1",
  "title": "zaki-read.v1",
  "$defs": {
    "Identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "CaptureNotice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bot_visible", "tenant_attested_at", "policy_version"],
      "properties": {
        "bot_visible": { "const": true },
        "tenant_attested_at": { "type": "string", "format": "date-time" },
        "policy_version": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "TranscriptRetention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "expires_at"],
      "properties": {
        "scope": { "const": "minutes.transcript" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "SummaryRetention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "expires_at"],
      "properties": {
        "scope": { "const": "minutes.summary" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "SpeakerTurn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker", "started_at", "text"],
      "properties": {
        "speaker": { "type": "string", "minLength": 1, "maxLength": 200 },
        "text": { "type": "string", "minLength": 1, "maxLength": 65536 },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" }
      }
    },
    "TranscriptContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "turns"],
      "properties": {
        "format": { "const": "speaker_turns" },
        "language": { "type": "string", "minLength": 2, "maxLength": 35 },
        "turns": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/SpeakerTurn" }
        }
      }
    },
    "TranscriptItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "meeting_id",
        "occurred_at",
        "updated_at",
        "sensitivity",
        "capture_notice",
        "retention",
        "content"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "transcript" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "meeting_id": { "$ref": "#/$defs/Identifier" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "capture_notice": { "$ref": "#/$defs/CaptureNotice" },
        "retention": { "$ref": "#/$defs/TranscriptRetention" },
        "content": {
          "oneOf": [
            { "$ref": "#/$defs/TranscriptContent" },
            { "$ref": "#/$defs/SummaryContent" }
          ]
        }
      }
    },
    "MeetingContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "started_at", "ended_at", "attendees"],
      "properties": {
        "platform": { "enum": ["google_meet", "teams", "zoom", "jitsi"] },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "attendees": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    },
    "MeetingItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "kind", "title", "occurred_at", "updated_at", "sensitivity",
        "capture_notice", "retention", "content"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "meeting" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "capture_notice": { "$ref": "#/$defs/CaptureNotice" },
        "retention": { "$ref": "#/$defs/TranscriptRetention" },
        "content": { "$ref": "#/$defs/MeetingContent" }
      }
    },
    "SummaryContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "text"],
      "properties": {
        "format": { "const": "summary" },
        "text": { "type": "string", "minLength": 1, "maxLength": 262144 }
      }
    },
    "SummaryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "kind", "title", "meeting_id", "occurred_at", "updated_at",
        "sensitivity", "retention", "content"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "summary" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "meeting_id": { "$ref": "#/$defs/Identifier" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "retention": { "$ref": "#/$defs/SummaryRetention" },
        "content": { "$ref": "#/$defs/SummaryContent" }
      }
    },
    "ItemResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item", "truncated"],
      "properties": {
        "item": {
          "oneOf": [
            { "$ref": "#/$defs/MeetingItem" },
            { "$ref": "#/$defs/TranscriptItem" },
            { "$ref": "#/$defs/SummaryItem" }
          ]
        },
        "truncated": { "const": false }
      }
    },
    "TranscriptMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "meeting_id",
        "occurred_at",
        "updated_at",
        "sensitivity",
        "retention"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "transcript" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "meeting_id": { "$ref": "#/$defs/Identifier" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "retention": { "$ref": "#/$defs/TranscriptRetention" }
      }
    },
    "MeetingMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title", "occurred_at", "updated_at", "sensitivity", "retention"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "meeting" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "retention": { "$ref": "#/$defs/TranscriptRetention" }
      }
    },
    "SummaryMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title", "meeting_id", "occurred_at", "updated_at", "sensitivity", "retention"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "kind": { "const": "summary" },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "meeting_id": { "$ref": "#/$defs/Identifier" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "sensitivity": { "const": "sensitive_pii" },
        "retention": { "$ref": "#/$defs/SummaryRetention" }
      }
    },
    "IndexResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "truncated"],
      "properties": {
        "items": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/MeetingMetadata" },
              { "$ref": "#/$defs/TranscriptMetadata" },
              { "$ref": "#/$defs/SummaryMetadata" }
            ]
          }
        },
        "truncated": { "type": "boolean" },
        "next_cursor": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      },
      "allOf": [
        {
          "if": { "properties": { "truncated": { "const": true } } },
          "then": { "required": ["next_cursor"] },
          "else": { "not": { "required": ["next_cursor"] } }
        }
      ]
    }
  }
}

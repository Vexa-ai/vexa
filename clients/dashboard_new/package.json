{
  "name": "@vexa/dashboard-new",
  "version": "0.1.0",
  "description": "Fresh modular dashboard, built per the repo brick paradigm: each concern is a self-contained brick under modules/ with one front door (src/index.ts), a README, and a test whose exit code is the signal. The 0.10.6 WS contract (core/gateway/contracts/ws.v1) is the consumed truth. The Next.js app here is the composition root that wires the bricks.",
  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:bricks": "for b in modules/*/; do (cd \"$b\" && npx tsc --watch --preserveWatchOutput &) ; done; wait",
    "build": "next build",
    "build:bricks": "for b in modules/*/; do (cd \"$b\" && npm run build) || exit 1; done",
    "start": "next start -p 3002",
    "test:bricks": "for b in modules/*/; do (cd \"$b\" && npm test) || exit 1; done"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vexa/dash-api-client": "*",
    "@vexa/dash-auth": "*",
    "@vexa/dash-chat": "*",
    "@vexa/dash-config": "*",
    "@vexa/dash-contracts": "*",
    "@vexa/dash-join-form": "*",
    "@vexa/dash-meeting-state": "*",
    "@vexa/dash-meetings-list": "*",
    "@vexa/dash-recording-players": "*",
    "@vexa/dash-status-history": "*",
    "@vexa/dash-transcript-viewer": "*",
    "@vexa/dash-vnc-view": "*",
    "@vexa/dash-ws": "*",
    "@vexa/dash-ws-event-log": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.3.1",
    "lucide-react": "^0.556.0",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0"
  }
}

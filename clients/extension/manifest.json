{
  "manifest_version": 3,
  "name": "Vexa — in-tab Google Meet transcription",
  "version": "0.1.0",
  "description": "Transcribe the Google Meet you are already in — no bot, no waiting room. Captures per-participant audio in your own tab and streams it to your Vexa desktop.",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "offscreen",
    "tabCapture",
    "scripting"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.youtube.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://teams.cloud.microsoft/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Vexa in-tab transcription",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.youtube.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": [
        "inpage.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.youtube.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "mic-permission.html",
        "vexa-pcm-worklet.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

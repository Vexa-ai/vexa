{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["chrome"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@vexa/gmeet-capture": ["../../meetings/modules/gmeet-capture/src/index.ts"],
      "@vexa/capture-codec": ["../../meetings/modules/capture-codec/src/index.ts"],
      "@vexa/mixed-capture-core": ["../../meetings/modules/mixed-capture-core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}

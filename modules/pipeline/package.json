{
  "name": "@vexa/pipeline",
  "version": "0.1.0",
  "description": "Pipeline core brick — per-speaker streams, VAD, name mapping, hallucination filter, stt.v1 client.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp -r src/hallucinations dist/hallucinations",
    "check:isolation": "node scripts/check-isolation.js",

# Synthetic-meeting eval harness — secrets (chmod 600, NEVER commit).
# cp secrets.env.example secrets.env  and fill in. (~/vexa-test-rig/secrets.env has the live values.)

# Production Vexa API base (the "ready-to-go" service that launches bots + serves /speak).
VEXA_BASE=https://api.vexa.ai

# The target meeting the bots join + speak into.
PLATFORM=teams                 # teams | zoom | google_meet
NATIVE_ID=                     # the meeting's native id (e.g. teams meeting id)

# Where the captured transcript is read for scoring (the transcription bot / desktop gateway).
TRANSCRIPTS_BASE=http://localhost:8056

# One production TEST-ACCOUNT bot token per speaker. A speaker is in the run iff its
# token is set — N tokens ⇒ an N-speaker meeting (cache holds 9 voices: A B V C D E F G H).
TOK_A=
TOK_B=
TOK_V=
TOK_C=
TOK_D=
# TOK_E=
# TOK_F=
# TOK_G=
# TOK_H=

# Deepgram key — ONLY needed to (re)generate the TTS clip pools (FORCE_REGEN=1). Not used per run.
DG_KEY=

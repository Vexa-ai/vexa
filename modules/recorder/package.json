{
  "name": "@vexa/recorder",
  "version": "0.1.0",
  "description": "Recorder brick \u2014 tees capture.v1 to a sink (training corpus / fixture).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "check:isolation": "node scripts/check-isolation.js",
    "capture": "node --env-file-if-exists=.env scripts/capture-recorder.mjs",
    "dump": "node --env-file-if-exists=.env scripts/dump.mjs",
    "sweep": "node --env-file-if-exists=.env scripts/dump.mjs sweep"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "ws": "^8.18.0"
  }
}
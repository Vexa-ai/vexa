# capture-recorder (npm run capture) — collect a capture.v1 fixture.
# Copy to .env if you need to change anything:  cp .env.example .env

# WS port the extension's sidepanel `ingestUrl` points at.
PORT=9099

# Fixture store root. Fixtures NEVER live in the repo. Default: ~/.vexa/fixtures
# VEXA_FIXTURE_CACHE=/abs/path/to/fixtures

# Override the auto name (default: <platform>-<native_meeting_id>).
# FIXTURE_NAME=zoom-standup-2026-06-14

# Set to 1 to also upload the fixture to the shared store (S3/MinIO) on stop.
# FIXTURE_S3=0
